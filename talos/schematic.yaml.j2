---
# This must match the schematic actually installed on the nodes
# (talosctl get extensions -> "schematic" pseudo-extension), or tuppr
# will refuse to build upgrade images. Schematic changes need a one-time
# manual `talosctl upgrade --image` transition; tuppr only does version bumps.
customization:
  extraKernelArgs:
    - -init_on_alloc # Less security, faster puter
    - -init_on_free # Less security, faster puter
    - -selinux # Less security, faster puter
    - apparmor=0 # Less security, faster puter
    - init_on_alloc=0 # Less security, faster puter
    - init_on_free=0 # Less security, faster puter
    # - pcie_aspm=off # Disable PCIe ASPM
    - mitigations=off # Less security, faster puter
    - security=none # Less security, faster puter
    - talos.auditd.disabled=1 # Less security, faster puter
  systemExtensions:
    officialExtensions:
      - siderolabs/i915
      - siderolabs/intel-ucode
      - siderolabs/mei # Intel iGPU
      - siderolabs/nfsrahead # NFS Performance
      - siderolabs/mdadm
      - siderolabs/util-linux-tools
